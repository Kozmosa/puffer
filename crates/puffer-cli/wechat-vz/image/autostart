#!/bin/bash
# Run by the openbox session (as the app user) once the desktop is ready. Sets up
# the AT-SPI accessibility environment BEFORE launching WeChat so the connector
# can drive the client through the accessibility tree, while keeping the normal
# runtime so the client still has network. The relaunch loop keeps WeChat up.

set -u

WECHAT_BIN=/config/wechat/opt/wechat/wechat
export LIBGL_ALWAYS_SOFTWARE=1   # no GPU in the container; force software rendering

# --- AT-SPI: session dbus + at-spi bus + accessibility env, BEFORE WeChat ---
export DISPLAY="${DISPLAY:-:1}"
export QT_ACCESSIBILITY=1 QT_LINUX_ACCESSIBILITY_ALWAYS_ON=1 GTK_MODULES="gail:atk-bridge"
# Resolve the at-spi bus launcher wherever this distro put it (Debian has shipped
# it under /usr/libexec and under /usr/lib/<triplet>/at-spi2-core across versions),
# so the a11y bus comes up on both the baked image and a runtime-provisioned base.
atspi_launcher=""
for p in /usr/libexec/at-spi-bus-launcher /usr/lib/at-spi2-core/at-spi-bus-launcher /usr/lib/*/at-spi2-core/at-spi-bus-launcher; do
    [ -x "$p" ] && { atspi_launcher="$p"; break; }
done
[ -n "$atspi_launcher" ] || atspi_launcher="$(command -v at-spi-bus-launcher 2>/dev/null || true)"
if command -v dbus-launch >/dev/null 2>&1 && [ -n "$atspi_launcher" ]; then
    eval "$(dbus-launch --sh-syntax)"
    # /run/wechat is created (abc-owned) by the seed cont-init; record the bus
    # address there so the connector's exec can reach the same a11y bus. Fall back
    # to the cache dir if /run is not writable (the reader mirrors both).
    printf '%s' "$DBUS_SESSION_BUS_ADDRESS" > /run/wechat/dbus-addr 2>/dev/null \
      || printf '%s' "$DBUS_SESSION_BUS_ADDRESS" > /config/.cache/wechat-dbus-addr 2>/dev/null || true
    "$atspi_launcher" --launch-immediately >/tmp/atspi.log 2>&1 &
    sleep 2
    dbus-send --session --type=method_call --dest=org.a11y.Bus /org/a11y/bus \
      org.freedesktop.DBus.Properties.Set string:org.a11y.Status string:ScreenReaderEnabled \
      variant:boolean:true 2>/dev/null || true
fi
# --- end AT-SPI setup ---

# openbox has no taskbar, so a minimized WeChat window cannot be restored. This
# watchdog re-activates any minimized (not-visible) top-level window every 2s.
(
    export DISPLAY="${DISPLAY:-:1}"
    while sleep 2; do
        all=$(xdotool search --name '.+' 2>/dev/null) || continue
        vis=$(xdotool search --onlyvisible --name '.+' 2>/dev/null)
        for w in ${all}; do
            printf '%s\n' "${vis}" | grep -qx "${w}" || xdotool windowactivate "${w}" 2>/dev/null || true
        done
    done
) &

# 1) Wait for WeChat to be present (the image pre-seeds the baked WeChat, so ready).
notified=0
while [ ! -x "${WECHAT_BIN}" ]; do
    if [ "${notified}" -eq 0 ]; then
        echo "[autostart] WeChat not ready yet, waiting..."
        notified=1
    fi
    sleep 2
done

# 2) Keep WeChat running (inherits the AT-SPI env + normal runtime above).
while true; do
    if [ ! -x "${WECHAT_BIN}" ]; then
        sleep 2
        continue
    fi
    echo "[autostart] launching WeChat: ${WECHAT_BIN}"
    "${WECHAT_BIN}"
    echo "[autostart] WeChat exited, restarting in 2s"
    sleep 2
done
