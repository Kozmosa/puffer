From f5631a5ad3778d1f2738cc9bacf3e7a63fa55aa8 Mon Sep 17 00:00:00 2001
From: Zaggy1024 <Zaggy1024@gmail.com>
Date: Fri, 19 Sep 2025 16:21:47 -0500
Subject: [PATCH 1/2] AK: Destroy non-trivial types by ref in
 HashTable::clear_with_capacity

Buckets being iterated by pointer instead of reference was causing a
compilation error when calling clear_with_capacity() on a HashTable
containing a non-trivially-destructible type.
---
 AK/HashTable.h | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/AK/HashTable.h b/AK/HashTable.h
index 5a846e09ba70e..2e0941b7348c3 100644
--- a/AK/HashTable.h
+++ b/AK/HashTable.h
@@ -346,8 +346,8 @@ class HashTable {
         if (m_capacity == 0)
             return;
         if constexpr (!IsTriviallyDestructible<T>) {
-            for (auto* bucket : *this)
-                bucket->~T();
+            for (auto& bucket : *this)
+                bucket.~T();
         }
         __builtin_memset(m_buckets, 0, size_in_bytes(m_capacity));
         m_size = 0;

From 654f2648bd539388318da31dfb2ed465626b3487 Mon Sep 17 00:00:00 2001
From: Zaggy1024 <Zaggy1024@gmail.com>
