 .../builtins/RegExp/RegExp.prototype.exec.js  |  58 ++++++++
 Libraries/LibRegex/RegexParser.cpp            |   7 +-
 Libraries/LibRegex/RegexParser.h              |   2 +-
 4 files changed, 154 insertions(+), 41 deletions(-)

