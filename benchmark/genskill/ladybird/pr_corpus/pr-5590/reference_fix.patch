 Libraries/LibRegex/RegexByteCode.h    | 16 ++++-
 Libraries/LibRegex/RegexOptimizer.cpp |  5 +-
 Libraries/LibRegex/RegexParser.cpp    |  4 +-
 Tests/LibRegex/TestRegex.cpp          | 90 ++++++++++++++++++++++++++
 5 files changed, 197 insertions(+), 9 deletions(-)

