{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Corbina",
  "version": "0.1.0",
  "identifier": "com.corbina.desktop",
  "build": {
    "beforeDevCommand": "npm run build:puffer-cli:dev && npm run dev",
    "beforeBuildCommand": "npm run build:puffer-cli:release && npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Corbina",
        "width": 1440,
        "height": 900,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": ["../../../resources/browser_extensions"]
  }
}
