    { "id": "draft-preserved-on-failure", "priority": 10, "description": "Prompt, URL, file, or settings drafts survive failed submits." },
    { "id": "one-request-per-intent", "priority": 10, "description": "Rapid user activation cannot submit duplicate effectful requests." },
    { "id": "stale-error-scoped", "priority": 10, "description": "Late errors are scoped to the object that caused them." },
    { "id": "controls-disabled-while-pending", "priority": 9, "description": "Effectful controls are disabled while their request is pending." },
    { "id": "no-cross-provider-model", "priority": 9, "description": "Provider/model state cannot cross between incompatible providers." },
