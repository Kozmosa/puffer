{
  "version": 1,
  "name": "puffer-desktop-playwright-fake-daemon",
  "description": "Action support map for converting generated fuzz cases into Playwright specs that use FakeDaemon.",
  "actions": [
    { "id": "open-workspace", "handler": "daemon.open(page)" },
    { "id": "open-agent-detail", "handler": "click sidebar/workspace agent card" },
    { "id": "open-browser-pane", "handler": "click Browser tab and wait for browser_open" },
    { "id": "open-settings-providers", "handler": "open Settings and select Providers pane" },
    { "id": "open-settings-mcp", "handler": "open Settings and select MCP Servers pane" },
    { "id": "open-permissions", "handler": "open Settings and select Permissions pane" },
    { "id": "open-new-agent", "handler": "click New agent in default workspace" },
    { "id": "open-connect-project", "handler": "click Connect project" },
    { "id": "open-workspace-picker", "handler": "click Switch workspace" },
    { "id": "assert-modal-initial-focus", "handler": "assert document.activeElement is contained by named dialog" },
    { "id": "assert-modal-focus-trap", "handler": "tab repeatedly from inside named dialog and assert focus stays inside" },
    { "id": "open-agent-card", "handler": "click a workspace agent card and wait for load_session_detail" },
    { "id": "type-url", "handler": "fill .pf-browser-address" },
    { "id": "press-address-enter", "handler": "press Enter in .pf-browser-address", "expectedMethod": "browser_navigate" },
    { "id": "click-new-tab", "handler": "click .pf-browser-tab-add", "expectedMethod": "browser_agent" },
    { "id": "close-active-tab", "handler": "click active browser tab close button", "expectedMethod": "browser_agent" },
    { "id": "switch-tab", "handler": "click indexed browser tab" },
    { "id": "reload", "handler": "click browser Reload button", "expectedMethod": "browser_reload" },
    { "id": "history", "handler": "click browser Back or Forward button", "expectedMethod": "browser_history" },
    { "id": "type-page-input", "handler": "focus browser canvas/page target and page.keyboard.type", "expectedMethod": "browser_input" },
    { "id": "special-key", "handler": "focus browser canvas/page target and page.keyboard.press", "expectedMethod": "browser_input" },
    { "id": "emit-state-for-old-tab", "handler": "daemon.emit browser:<session>:browser:<tab>:state" },
    { "id": "emit-frame-burst", "handler": "loop daemon.emit browser:<session>:browser:<tab>:frame" },
    { "id": "emit-empty-tab-list", "handler": "daemon.emit browser:<session>:tabs with empty tabs" },
    { "id": "fail-next-browser-command", "handler": "daemon.failNext on browser method" },
    { "id": "hold-next-browser-response", "handler": "daemon.delayResponse on browser method with long delay" },
    { "id": "type-composer", "handler": "fill chat composer" },
    { "id": "send-prompt", "handler": "click chat send", "expectedMethod": "run_agent_turn" },
    { "id": "rapid-send-prompt", "handler": "double-activate chat send and assert one run_agent_turn", "expectedMethod": "run_agent_turn" },
    { "id": "stop-turn", "handler": "click chat stop", "expectedMethod": "cancel_turn" },
    { "id": "complete-turn", "handler": "daemon.emit active session turn-complete and wait for Send" },
    { "id": "settle-canceled-turn", "handler": "daemon.emit active session turn-error after cancel and wait for Send" },
    { "id": "switch-session", "handler": "click another sidebar/workspace session" },
    { "id": "emit-old-session-stream", "handler": "daemon.emit session:<session>:event with stale stream event" },
    { "id": "emit-permission", "handler": "daemon.emit session:<session>:event with permission-request" },
    { "id": "answer-permission", "handler": "click permission approve/deny", "expectedMethod": "resolve_permission" },
    { "id": "emit-question", "handler": "daemon.emit session:<session>:event with user-question" },
    { "id": "answer-question", "handler": "submit question answer", "expectedMethod": "resolve_user_question" },
    { "id": "change-model", "handler": "open chat model picker and select model" },
    { "id": "delayed-transcript-refresh", "handler": "daemon.delayResponse load_session_detail" },
    { "id": "import-credential", "handler": "click provider external credential import", "expectedMethod": "import_external_credential" },
    { "id": "refresh-credential", "handler": "click provider login/refresh action", "expectedMethod": "login_with_oauth" },
    { "id": "save-default-model-codex", "handler": "click Settings Save default for Codex provider", "expectedMethod": "update_config" },
    { "id": "save-default-model-anthropic", "handler": "click Settings Save default for Anthropic provider", "expectedMethod": "update_config" },
    { "id": "switch-new-agent-provider-codex", "handler": "select Codex provider in New agent modal" },
    { "id": "switch-new-agent-provider-anthropic", "handler": "select Anthropic provider in New agent modal" },
    { "id": "submit-new-agent", "handler": "click Start agent", "expectedMethod": "create_session" },
    { "id": "emit-auth-list-refresh", "handler": "daemon.setAuthStatuses then reload/emit workspace refresh as needed" },
    { "id": "emit-auth-one-provider-refresh", "handler": "daemon.setAuthStatuses with one authenticated provider then reload Settings snapshot" },
    { "id": "emit-auth-none-refresh", "handler": "daemon.setAuthStatuses with no authenticated providers then reload Settings snapshot" },
    { "id": "delayed-model-list", "handler": "daemon.delayResponse list_provider_models" },
    { "id": "type-search", "handler": "fill workspace search" },
    { "id": "clear-search", "handler": "clear workspace search" },
    { "id": "pin-agent", "handler": "click agent pin control", "expectedMethod": "set_desktop_pin" },
    { "id": "emit-grouped-session-refresh", "handler": "daemon.emit workspace:sessions:changed" },
    { "id": "emit-active-agent-change", "handler": "daemon.emit workspace:sessions:changed or session:<session>:event" },
    { "id": "open-file", "handler": "open Files pane and select file", "expectedMethod": "read_file" },
    { "id": "edit-file", "handler": "type into file editor" },
    { "id": "save-file", "handler": "click file save", "expectedMethod": "write_file" },
    { "id": "emit-file-restore", "handler": "daemon.emit workspace:fs:changed" },
    { "id": "open-terminal", "handler": "open Terminal pane and create pty", "expectedMethod": "pty_open" },
    { "id": "type-terminal", "handler": "write terminal input", "expectedMethod": "pty_write" },
    { "id": "close-terminal", "handler": "close active terminal", "expectedMethod": "pty_close" },
    { "id": "emit-late-pty-output", "handler": "daemon.emit pty:<pty>:data" },
    { "id": "add-mcp-server", "handler": "submit Settings MCP add form", "expectedMethod": "add_mcp_server" },
    { "id": "emit-mcp-list-refresh", "handler": "reload list_mcp_servers or emit workspace refresh" },
    { "id": "late-mcp-test-result", "handler": "emit/delay a stale MCP test result if supported by target test" },
    { "id": "save-permissions", "handler": "click Settings Permissions save", "expectedMethod": "save_permissions" },
    { "id": "emit-permissions-refresh", "handler": "reload list_permissions after local edit" },
    { "id": "disconnect-reconnect", "handler": "FakeDaemon.disconnectAllSockets and wait for reconnect/disconnected UI state" },
    { "id": "resize-narrow", "handler": "page.setViewportSize narrow" },
    { "id": "resize-desktop", "handler": "page.setViewportSize desktop" },
    { "id": "open-pipelines", "handler": "open Pipelines screen" },
    { "id": "edit-pipeline-node", "handler": "edit pipeline node field" },
    { "id": "edit-pipeline-trigger", "handler": "edit pipeline trigger field" },
    { "id": "emit-pipeline-refresh", "handler": "simulate workflow list refresh if available" }
  ],
  "eventPatterns": [
    { "id": "browser:<session>:browser:<tab>:state" },
    { "id": "browser:<session>:browser:<tab>:frame" },
    { "id": "browser:<session>:tabs" },
    { "id": "session:<session>:event" },
    { "id": "workspace:sessions:changed" },
    { "id": "workspace:fs:changed" },
    { "id": "pty:<pty>:data" }
  ]
}
